{
  "name": "desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Sage Agent 桌面壳（Electron）",
  "author": "Sage Agent",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently -k -n web,electron -c blue,green \"pnpm --filter web dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron": "electron .",
    "prepare:standalone": "node scripts/copy-standalone-assets.mjs",
    "app:pack": "pnpm prepare:standalone && electron-builder --dir",
    "app:dist": "pnpm prepare:standalone && electron-builder"
  },
  "build": {
    "appId": "com.sage.agent",
    "productName": "Sage Agent",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../web/.next/standalone",
        "to": "standalone"
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools"
    }
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "wait-on": "^8.0.1"
  }
}
